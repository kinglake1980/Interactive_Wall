{
  "name": "interactive-wall",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "现场互动墙 - 最小可运行骨架（暂无功能切片）",
  "scripts": {
    "postinstall": "npm --prefix web install",
    "server": "node server/index.js",
    "test": "node --test \"test/**/*.test.js\"",
    "web": "npm --prefix web run dev",
    "dev": "concurrently -n server,web -c blue,green \"npm run server\" \"npm run web\"",
    "build": "npm --prefix web run build"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
